# SentinelMind Environment Variables
# Copy this to .env and fill in your values

APP_NAME=SentinelMind
VERSION=0.1.0
DEBUG=true

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Security
API_KEY_SECRET=change-this-to-a-long-random-string

# Database
DATABASE_URL=sqlite:///./sentinelmind.db

# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key_here
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# Redis (optional for dev)
REDIS_URL=redis://localhost:6379
